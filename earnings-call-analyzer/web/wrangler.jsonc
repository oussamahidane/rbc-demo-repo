{
  // Cloudflare Pages project for the Earnings-Call Analyzer web interface.
  // Functions in functions/ run on the Workers runtime (this is the "Workers + Pages" pairing).
  "name": "eca-web",
  "compatibility_date": "2025-01-01",
  "pages_build_output_dir": "public",

  // Non-secret vars only. Secrets (ANTHROPIC_API_KEY, APP_PASSWORD) are set out-of-band:
  //   npx wrangler pages secret put ANTHROPIC_API_KEY
  //   npx wrangler pages secret put APP_PASSWORD
  // For local dev, put them in .dev.vars (gitignored). See README-web.md.
  "vars": {
    "ECA_MODEL": "claude-opus-4-8",
    "RATE_LIMIT_BUDGET": "5.0",
    "RATE_LIMIT_WINDOW_DAYS": "7"
  }
}
